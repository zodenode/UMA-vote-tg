# Telegram
BOT_TOKEN=
WEB_APP_URL=https://your-mini-app-host.example
PUBLIC_BOT_USERNAME=YourBotName
# Shared secret so the bot can call internal API routes (alerts, ensure-user)
INTERNAL_API_SECRET=

# API (used by bot + mini app backend)
API_PUBLIC_URL=http://localhost:8787

# Server (local API default). On Railway do not set PORT — the platform injects it (e.g. 8080).
PORT=8787
DATABASE_PATH=./data/uma-vote.db
CRON_SECRET=

# Ethereum JSON-RPC — required for DVM phase timing (VotingV2) + optional Ethereum OO dispute indexing
ETH_RPC_URL=
# First poll: scan this many past blocks for Ethereum OOv2 logs (default 4000)
OO_LOOKBACK_BLOCKS=4000

# Polygon JSON-RPC — optional; indexes Polygon OptimisticOracleV2 DisputePrice (Polymarket-style activity)
POLYGON_RPC_URL=
# First Polygon poll lookback (defaults to OO_LOOKBACK_BLOCKS if unset)
OO_POLYGON_LOOKBACK_BLOCKS=4000

# How often to poll for new DisputePrice logs on each configured chain (ms)
DISPUTE_POLL_MS=12000
# Comma-separated requester addresses to tag as Polymarket (optional; we also match "polymarket" in ancillary UTF-8)
POLYMARKET_REQUESTER_ADDRESSES=

# The Graph gateway (UMA mainnet voting subgraph)
THEGRAPH_API_KEY=

# 0x Swap API — https://0x.org/docs/
ZEROX_API_KEY=

# Fee recipient (your address) + integrator fee in basis points (e.g. 25 = 0.25%)
FEE_RECIPIENT=
INTEGRATOR_FEE_BPS=50

# Bot: how often to check for new disputed queries to broadcast (ms)
DISPUTE_ALERT_INTERVAL_MS=45000

# Mini app (Vite)
VITE_API_URL=http://localhost:8787
VITE_PUBLIC_BOT_USERNAME=YourBotName

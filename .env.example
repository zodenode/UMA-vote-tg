# Telegram
BOT_TOKEN=
WEB_APP_URL=https://your-mini-app-host.example
PUBLIC_BOT_USERNAME=YourBotName
# Optional: “Share dispute search” menu rows (switch_inline). Requires @BotFather → Bot Settings → Inline mode ON, or Telegram rejects /start. Leave unset for the default (no share rows).
# BOT_INLINE_SHARE=1
# Optional: /start sends a welcome photo (HTTPS URL or Telegram file_id after you upload once) + HTML caption
# WELCOME_PHOTO_URL=https://your-cdn.example/uma-vote-welcome.png
# WELCOME_PHOTO_FILE_ID=
# Shared secret so the bot can call internal API routes (alerts, ensure-user)
INTERNAL_API_SECRET=

# API (used by bot + mini app backend)
API_PUBLIC_URL=http://localhost:8787

# Custodial vault: 32-byte master key for AES-256-GCM (e.g. `openssl rand -hex 32`). Set only on the API service in prod.
VAULT_MASTER_KEY=

# Server (local API default). On Railway do not set PORT — the platform injects it (e.g. 8080).
PORT=8787
DATABASE_PATH=./data/uma-vote.db
CRON_SECRET=

# Community petitions (Telegram + Mini App). Export uses GET /api/cron/petition-export?secret=CRON_SECRET&petitionId=<hex>
# PETITION_MAX_TITLE_CHARS=120
# PETITION_MAX_BODY_CHARS=2000
# PETITION_MAX_COMMENT_CHARS=200
# PETITION_CREATES_PER_DAY=8
# Set to 1 to include raw signer telegram_id in CSV (default: SHA-256-derived opaque id per signer)
# PETITION_EXPORT_INCLUDES_USERNAME=0
# Optional User-Agent for Wikimedia Commons (petition cover image suggestions). Wikimedia prefers a contact URL.
# WIKIMEDIA_API_USER_AGENT=MyService/1.0 (https://example.com; contact@example.com)

# Ethereum JSON-RPC — required for DVM phase timing (VotingV2) + optional Ethereum OO dispute indexing
# Default: public endpoint from chainlist.org / ethereum-lists/chains (no API key). Prefer Alchemy/Infura in production.
# Use https://… (JSON-RPC over HTTP). If you only have wss://, the API maps it to https:// on the same host (e.g. PublicNode).
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
# First poll: scan this many past blocks for Ethereum OOv2 logs (default 20000; widen if API was down for days)
OO_LOOKBACK_BLOCKS=20000

# Polygon JSON-RPC — indexes Polygon OptimisticOracleV2 DisputePrice (Polymarket-style activity)
# Default: public endpoint from chainlist.org / ethereum-lists/chains. Prefer a dedicated provider in production.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
# First Polygon poll lookback (defaults to OO_LOOKBACK_BLOCKS if set, else 80000 — ~2d so cold DBs still see disputes)
OO_POLYGON_LOOKBACK_BLOCKS=80000
# eth_getLogs max span (toBlock - fromBlock); publicnode caps ~1000 — default 999 in code (override for Alchemy etc.)
# OO_LOG_CHUNK_BLOCKS=999

# How often to poll for new DisputePrice logs on each configured chain (ms)
DISPUTE_POLL_MS=12000
# Comma-separated requester addresses to tag as Polymarket (optional; we also match "polymarket" in ancillary UTF-8)
POLYMARKET_REQUESTER_ADDRESSES=

# The Graph — UMA mainnet voting subgraph (https://docs.uma.xyz/resources/subgraph-data). Create your own API key in Subgraph Studio.
# If unset or the subgraph returns an error, the API falls back to VotingV2 logs when ETH_RPC_URL is set.
THEGRAPH_API_KEY=
# THEGRAPH_GATEWAY_BASE=https://gateway-arbitrum.network.thegraph.com/api
# VOTING_SUBGRAPH_ID=

# On-chain DVM request list (used when The Graph fails). Scans backward from chain tip.
# VOTING_REQUEST_LOG_LOOKBACK_BLOCKS=80000
# VOTING_REQUEST_LOG_CHUNK_BLOCKS=999
# VOTING_REQUEST_LOG_STOP_UNIQUE=140
# Longer timeout for heavy eth_getLogs (ms)
# ETH_HTTP_TIMEOUT_MS=120000

# 0x Swap API — https://0x.org/docs/
ZEROX_API_KEY=

# Fee recipient (your address) + integrator fee in basis points (e.g. 25 = 0.25%)
FEE_RECIPIENT=
INTEGRATOR_FEE_BPS=50

# Bot: how often to check for new disputed queries to broadcast (ms)
DISPUTE_ALERT_INTERVAL_MS=45000

# Mini app (Vite)
VITE_API_URL=http://localhost:8787
VITE_PUBLIC_BOT_USERNAME=YourBotName
# Mini app wagmi transports — defaults match chainlist.org / ethereum-lists/chains public RPCs; override for production.
# wss:// (or ws://) is normalized to https:// (or http://) on the same host for JSON-RPC over HTTP.
VITE_POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
VITE_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
# Optional dedicated providers (replace defaults above):
# VITE_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/KEY
# VITE_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/KEY
# WalletConnect (mobile Telegram / no injected wallet) — project id from https://cloud.reown.com/
# VITE_WALLETCONNECT_PROJECT_ID=

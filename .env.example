# =============================================================================
# Environment variables — local vs production
# =============================================================================
# Copy to `.env` for local dev. In production (e.g. Railway), set variables per
# SERVICE — not every key belongs on every process. See comments below and
# deploy/railway.yml for the split.
# =============================================================================

# --- Shared secrets (same value on API + bot in prod) ---
BOT_TOKEN=
INTERNAL_API_SECRET=
CRON_SECRET=

# --- URLs (local = localhost; prod = HTTPS Railway domains) ---
# Bot + Telegram Mini App: must be public HTTPS in prod
WEB_APP_URL=https://your-mini-app-host.example
# Bot fetches this; Mini App browser also uses VITE_API_URL (build-time)
API_PUBLIC_URL=http://localhost:8787

# Optional: for log warnings / referral links
PUBLIC_BOT_USERNAME=YourBot

# --- API service only ---
PORT=8787
# Local: ./data/uma-vote.db | Prod: /data/uma-vote.db with a persistent volume
DATABASE_PATH=./data/uma-vote.db

ETH_RPC_URL=
OO_LOOKBACK_BLOCKS=4000
DISPUTE_POLL_MS=12000
POLYMARKET_REQUESTER_ADDRESSES=

THEGRAPH_API_KEY=
ZEROX_API_KEY=
FEE_RECIPIENT=
INTEGRATOR_FEE_BPS=25

# Bot loops (API uses CRON_SECRET for endpoints; bot uses these intervals)
DIGEST_INTERVAL_MS=3600000
DISPUTE_ALERT_INTERVAL_MS=45000

# --- Mini App build (Vite) — local dev / Railway WEB service build step ---
# In prod, VITE_API_URL must be your public API URL before `npm run build -w apps/web`
VITE_API_URL=http://localhost:8787
VITE_PUBLIC_BOT_USERNAME=YourBot

# =============================================================================
# Quick reference: who needs what?
# =============================================================================
#
# | Variable                 | API | Bot | Web (build) |
# |--------------------------|-----|-----|-------------|
# | BOT_TOKEN                |  ✓  |  ✓  |             |
# | INTERNAL_API_SECRET      |  ✓  |  ✓  |             |
# | CRON_SECRET              |  ✓  |  ✓  |             |
# | API_PUBLIC_URL           |  ✓  |  ✓  |             |
# | WEB_APP_URL              |     |  ✓  |             |
# | PUBLIC_BOT_USERNAME      |     | opt |             |
# | PORT                     |  ✓  |     |  ✓ (Railway)|
# | DATABASE_PATH            |  ✓  |     |             |
# | ETH_RPC_URL … POLY…      |  ✓  |     |             |
# | THEGRAPH_API_KEY         |  ✓  |     |             |
# | ZEROX_* , FEE_*          |  ✓  |     |             |
# | DIGEST_* , DISPUTE_*     |     |  ✓  |             |
# | VITE_API_URL             |     |     |  ✓          |
# | VITE_PUBLIC_BOT_USERNAME |     |     |  ✓          |
#
# Production differences from local:
# - API_PUBLIC_URL / WEB_APP_URL / VITE_API_URL → https://… (no localhost)
# - PORT → Railway sets automatically; do not hardcode 8787 in prod unless you override
# - DATABASE_PATH → /data/uma-vote.db + volume (local ./data is fine for dev)
# - VITE_* → only at build time on the web service; rebuild web when API URL changes
# - Bot: disable HTTP healthcheck on Railway (no web server)
# - Never commit real tokens; use Railway variable references for shared secrets
#
# Full deploy checklist: README.md "Deploy to production (Railway)"
# =============================================================================

# Telegram
BOT_TOKEN=
WEB_APP_URL=https://your-mini-app-host.example
PUBLIC_BOT_USERNAME=YourBot
# Shared secret so the bot can call internal API routes (alerts, ensure-user)
INTERNAL_API_SECRET=

# API (used by bot + mini app backend)
API_PUBLIC_URL=http://localhost:8787

# Server
PORT=8787
DATABASE_PATH=./data/uma-vote.db
CRON_SECRET=change-me-long-random

# The Graph gateway (UMA mainnet voting subgraph)
# https://docs.uma.xyz/resources/subgraph-data
THEGRAPH_API_KEY=

# 0x Swap API — https://0x.org/docs/
ZEROX_API_KEY=

# Fee recipient (your address) + integrator fee in basis points (e.g. 25 = 0.25%)
FEE_RECIPIENT=
INTEGRATOR_FEE_BPS=25

# Mini app (Vite)
VITE_API_URL=http://localhost:8787
VITE_PUBLIC_BOT_USERNAME=YourBot
